{
  "name": "@lemma/api",
  "main": "src/trpc/routers/_app.ts",
  "types": "src/trpc/routers/_app.ts",
  "scripts": {
    "dev": "bun run src/index.ts",
    "worker": "bun run src/worker.ts",
    "worker:dev": "bun --watch run src/worker.ts",
    "generate-migration": "drizzle-kit generate",
    "typecheck": "tsc --noEmit",
    "migrate:local": "bun run ./scripts/migrate.ts",
    "migrate:prod": "cross-env NODE_ENV=production bun run ./scripts/migrate.ts",
    "seed-slugs:local": "bun run ./scripts/seed-slugs.ts",
    "seed-slugs:prod": "cross-env NODE_ENV=production bun run ./scripts/seed-slugs.ts"
  },
  "dependencies": {
    "@escape.tech/graphql-armor-cost-limit": "2.4.3",
    "@escape.tech/graphql-armor-max-depth": "2.4.2",
    "@escape.tech/graphql-armor-max-tokens": "2.5.1",
    "@graphql-yoga/plugin-disable-introspection": "2.19.0",
    "@hono/trpc-server": "^0.4.0",
    "@hono/zod-openapi": "^1.1.0",
    "@lemma/common": "workspace:*",
    "@lemma/email": "workspace:*",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.208.0",
    "@opentelemetry/instrumentation": "0.208.0",
    "@opentelemetry/instrumentation-http": "0.208.0",
    "@opentelemetry/resources": "2.2.0",
    "@opentelemetry/sdk-node": "0.208.0",
    "@opentelemetry/sdk-trace-base": "2.2.0",
    "@opentelemetry/sdk-trace-node": "2.2.0",
    "@opentelemetry/semantic-conventions": "1.38.0",
    "@react-email/render": "^1.1.3",
    "@scalar/hono-api-reference": "^0.9.16",
    "@sentry/node": "10.32.1",
    "@sentry/opentelemetry": "10.32.1",
    "@sentry/profiling-node": "10.32.1",
    "@trpc/server": "^11.4.3",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.2.12",
    "bullmq": "^5.34.8",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.2",
    "graphql": "16.12.0",
    "graphql-yoga": "5.18.0",
    "hono": "^4.8.4",
    "ioredis": "^5.4.2",
    "jimp": "^1.6.0",
    "ksuid": "^3.0.0",
    "neverthrow": "^8.2.0",
    "postgres": "^3.4.7",
    "resend": "^4.6.0",
    "slugify": "^1.6.6",
    "superjson": "^2.2.2",
    "winston": "3.19.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.1.0",
    "cross-env": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "5.9.3"
  }
}
