{
  "name": "@lemma/api",
  "main": "src/trpc/routers/_app.ts",
  "types": "src/trpc/routers/_app.ts",
  "scripts": {
    "dev": "wrangler dev --env local --port 4000",
    "cf-typegen": "cross-env CLOUDFLARE_LOAD_DEV_VARS_FROM_DOT_ENV=false wrangler types --env local",
    "deploy:production": "wrangler deploy --env production",
    "generate-migration": "drizzle-kit generate",
    "typecheck": "tsc --noEmit",
    "migrate:local": "cross-env ENV=local bun run ./scripts/migrate.ts",
    "migrate:production": "cross-env ENV=production bun run ./scripts/migrate.ts",
    "seed-slugs:local": "cross-env ENV=local bun run ./scripts/seed-slugs.ts",
    "seed-slugs:production": "cross-env ENV=production bun run ./scripts/seed-slugs.ts"
  },
  "dependencies": {
    "@escape.tech/graphql-armor-cost-limit": "2.4.3",
    "@escape.tech/graphql-armor-max-depth": "2.4.2",
    "@escape.tech/graphql-armor-max-tokens": "2.5.1",
    "@graphql-yoga/plugin-disable-introspection": "2.19.0",
    "@hono/trpc-server": "^0.4.0",
    "@hono/zod-openapi": "^1.1.0",
    "@lemma/common": "workspace:*",
    "@lemma/email": "workspace:*",
    "@react-email/render": "^1.1.3",
    "@scalar/hono-api-reference": "^0.9.16",
    "@sentry/cloudflare": "^10.32.1",
    "@sindresorhus/slugify": "3.0.0",
    "@trpc/server": "^11.4.3",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.2.12",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.2",
    "graphql": "16.12.0",
    "graphql-yoga": "5.18.0",
    "hono": "^4.8.4",
    "jimp": "^1.6.0",
    "ksuid": "^3.0.0",
    "neverthrow": "^8.2.0",
    "postgres": "^3.4.7",
    "resend": "^4.6.0",
    "slugify": "^1.6.6",
    "superjson": "^2.2.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.1.0",
    "cross-env": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "5.9.3",
    "wrangler": "^4.26.0"
  }
}
