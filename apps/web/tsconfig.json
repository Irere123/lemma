{
  "include": [
    ".react-router/types/**/*",
    "src/**/*",
    "src/**/.server/**/*",
    "src/**/.client/**/*",
    "workers/**/*",
    "vite.config.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "checkJs": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "noEmit": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["vite/client", "node", "./worker-configuration.d.ts"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "@/*": ["./src/*"],
      "@api/*": ["../api/src/*"]
    },
    "esModuleInterop": true,
    "resolveJsonModule": true
  }
}
