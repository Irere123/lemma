# Lemma API Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# ENVIRONMENT
# =============================================================================
ENV=development
PORT=4000

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_USER=lemma
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=lemma
# For external database, use full connection string:
# DATABASE_URL=postgresql://user:password@host:5432/database

# =============================================================================
# REDIS (BullMQ Job Queue)
# =============================================================================
# For external Redis, use full connection string:
# REDIS_URL=redis://user:password@host:6379

# =============================================================================
# API CONFIGURATION
# =============================================================================
ALLOWED_API_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# =============================================================================
# SECURITY
# =============================================================================
# Generate with: openssl rand -hex 32
LEMMA_ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:4000

# Admin user ID (first user to be created)
ADMIN_USER_ID=admin_user_id_here

# =============================================================================
# CLOUDFLARE R2 STORAGE
# =============================================================================
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_URL=https://your-bucket.r2.cloudflarestorage.com
R2_STORAGE_BASE_URL=https://your-public-r2-url.com

# =============================================================================
# EMAIL (Resend)
# =============================================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_DOMAIN=your-sending-domain.com

# =============================================================================
# OAUTH PROVIDERS
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
