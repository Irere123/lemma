{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "brainos-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-07-12",
  "compatibility_flags": ["nodejs_compat"],
  "keep_vars": true,
  "dev": {
    "port": 4000,
  },
  "env": {
    "local": {
      "observability": {
        "enabled": true,
      },
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "14e911afb02544e6b90b8d2a917b1105",
          "localConnectionString": "postgres://postgres:postgres@localhost:5432/brainos",
        },
      ],
      "vars": {
        "NODE_ENV": "development",
        "PORT": 4000,
      },
      "kv_namespaces": [
        {
          "binding": "CACHE_KV",
          "id": "e679d852f8094948baf97528648abc31",
        },
        {
          "binding": "QUEUE_SHARDS_KV",
          "id": "6df1aad1a26c4354adc1becbd910f709",
        },
      ],
      "migrations": [
        {
          "new_sqlite_classes": ["QueueDurableObject"],
          "tag": "v1",
        },
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "EMAIL_QUEUE_SHARD",
            "class_name": "QueueDurableObject",
          },
        ],
      },
    },
    "production": {
      "observability": {
        "enabled": true,
      },
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "14e911afb02544e6b90b8d2a917b1105",
          "localConnectionString": "postgres://postgres:postgres@localhost:5432/brainos",
        },
      ],
      "vars": {
        "NODE_ENV": "development",
        "PORT": 4000,
      },
      "kv_namespaces": [
        {
          "binding": "CACHE_KV",
          "id": "e679d852f8094948baf97528648abc31",
        },
        {
          "binding": "QUEUE_SHARDS_KV",
          "id": "6df1aad1a26c4354adc1becbd910f709",
        },
      ],
      "migrations": [
        {
          "new_sqlite_classes": ["QueueDurableObject"],
          "tag": "v1",
        },
      ],
      "durable_objects": {
        "bindings": [
          {
            "name": "EMAIL_QUEUE_SHARD",
            "class_name": "QueueDurableObject",
          },
        ],
      },
    },
  },
}
