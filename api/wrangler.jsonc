{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "brainos-api",
  "main": "src/index.ts",
  "compatibility_date": "2025-07-12",
  "compatibility_flags": ["nodejs_compat"],
  "keep_vars": true,
  "durable_objects": {
    "bindings": [
      {
        "name": "EMAIL_QUEUE_SHARD",
        "class_name": "QueueDurableObject",
        "script_name": "brainos-api",
      },
    ],
  },
  "dev": {
    "port": 4000,
  },
  "env": {
    "local": {
      "observability": {
        "enabled": true,
      },
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "14e911afb02544e6b90b8d2a917b1105",
          "localConnectionString": "postgres://postgres:postgres@localhost:5432/brainos",
        },
      ],
      "vars": {
        "NODE_ENV": "development",
        "PORT": 4000,
      },
      "kv_namespaces": [
        {
          "binding": "CACHE_KV",
          "id": "e679d852f8094948baf97528648abc31",
        },
        {
          "binding": "QUEUE_SHARDS_KV",
          "id": "preview_id",
        },
      ],
    },
    "production": {
      "observability": {
        "enabled": true,
      },
      "hyperdrive": [
        {
          "binding": "HYPERDRIVE",
          "id": "14e911afb02544e6b90b8d2a917b1105",
          "localConnectionString": "postgres://postgres:postgres@localhost:5432/brainos",
        },
      ],
      "vars": {
        "NODE_ENV": "development",
        "PORT": 4000,
      },
      "kv_namespaces": [
        {
          "binding": "CACHE_KV",
          "id": "e679d852f8094948baf97528648abc31",
        },
        {
          "binding": "QUEUE_SHARDS_KV",
          "id": "production_id",
        },
      ],
    },
  },
}
