{
  "name": "@brain/api",
  "main": "src/trpc/routers/_app.ts",
  "types": "src/trpc/routers/_app.ts",
  "scripts": {
    "dev": "wrangler dev --env local",
    "deploy": "wrangler deploy --minify --env production",
    "types": "wrangler types --env local",
    "generate-migration": "drizzle-kit generate",
    "migrate:local": "bun run ./scripts/migrate.ts",
    "migrate:prod": "cross-env NODE_ENV=production bun run ./scripts/migrate.ts",
    "seed-slugs:local": "bun run ./scripts/seed-slugs.ts",
    "seed-slugs:prod": "cross-env NODE_ENV=production bun run ./scripts/seed-slugs.ts"
  },
  "dependencies": {
    "@brain/common": "workspace:*",
    "@brain/email": "workspace:*",
    "@hono/trpc-server": "^0.4.0",
    "@hono/zod-openapi": "^1.1.0",
    "@scalar/hono-api-reference": "^0.9.16",
    "@trpc/server": "^11.4.3",
    "aws4fetch": "^1.0.20",
    "better-auth": "^1.2.12",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.44.2",
    "hono": "^4.8.4",
    "jimp": "^1.6.0",
    "ksuid": "^3.0.0",
    "neverthrow": "^8.2.0",
    "postgres": "^3.4.7",
    "resend": "^4.6.0",
    "slugify": "^1.6.6",
    "superjson": "^2.2.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^24.1.0",
    "cross-env": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "wrangler": "^4.46.0"
  }
}
