
# ------------------------------------------------------------------------
# REQUIRED ENV VARIABLES
# ------------------------------------------------------------------------

# AUTH
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:8080
BETTER_AUTH_URL=http://localhost:3000
ALLOWED_API_ORIGINS=http://localhost:5173,http://localhost:3000,https://irere.dev
PORT=4000
BRAIN_ENCRYPTION_KEY=my_encryption_key ## should be 32-byte hex value
ADMIN_USER_ID=platform_user_id ## irere's user id

# DATABASE
# You can grab this from the Supabase dashboard by pressing the "Connect" button in the upper navbar, or pass in your own connection string to a postgres instance

DATABASE_URL=
PROD_DATABASE_URL=

#CLOUFLARE R2 Storage
CLOUDFLARE_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_URL=https://${CLOUDFLARE_ACCOUNT_ID}.r2.cloudflarestorage.com/<bucket-name>
R2_STORAGE_BASE_URL={URL your assets as available at} # https://static.example.com

# RESEND 
RESEND_API_KEY=your_api_key
RESEND_DOMAIN=irere.dev
